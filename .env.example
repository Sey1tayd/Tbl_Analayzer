# Railway'de bu değerleri Environment Variables olarak gir:

SECRET_KEY=gizli-bir-anahtar-buraya-yaz
DEBUG=False
ALLOWED_HOSTS=*.railway.app,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app

# Railway PostgreSQL eklediğinde otomatik gelir:
DATABASE_URL=postgresql://user:pass@host:5432/dbname
